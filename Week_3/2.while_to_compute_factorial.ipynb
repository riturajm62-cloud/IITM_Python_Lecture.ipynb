   "source": [
    "print(\"Enter a number!\")\n",
    "n=int(input())\n",
    "\n",
    "i=1\n",
    "answer=1\n",
    "while(i<=n):\n",
    "    answer=answer*i\n",
    "    i=i+1\n",
    "print(answer)\n"
